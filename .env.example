# Gemini API Credentials (Required for AI pricing assistant)
GEMINI_API_KEY=

# MongoDB Connection String (e.g., mongodb+srv://username:password@cluster.mongodb.net/food_rescue)
# If left blank, the system automatically runs on a high-speed fallback in-memory database simulation.
MONGODB_URI=

# Google OAuth Credentials for actual federated verification
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
